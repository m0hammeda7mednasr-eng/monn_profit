# Core app
PORT=5000
NODE_ENV=development
# Prefer a dedicated app JWT secret in production.
# If this is omitted, the backend will temporarily fall back to SUPABASE_SERVICE_ROLE_KEY.
JWT_SECRET=your_super_secret_and_long_jwt_key

# Public URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional fallback only. Do not rely on this for backend writes in production.
SUPABASE_KEY=your_supabase_anon_key

# Shopify app credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Optional Shopify settings
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret
SHOPIFY_API_VERSION=2024-01

# Emergency read-only fallback when the primary database is unavailable.
# Create this token from Shopify Admin with read_orders access, then remove it
# after database service is healthy again or after migration is complete.
SHOPIFY_EMERGENCY_SHOP=your-store.myshopify.com
SHOPIFY_EMERGENCY_ACCESS_TOKEN=shpat_or_admin_api_access_token
